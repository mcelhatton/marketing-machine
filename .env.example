# MDD Marketing Machine Environment Variables
# Copy this file to .env and fill in your values

# ============================================
# HubSpot Configuration
# ============================================

# HubSpot Portal ID
HUBSPOT_PORTAL_ID=585393

# HubSpot Personal Access Key
# Get from: HubSpot > Settings > Integrations > Private Apps
HUBSPOT_ACCESS_TOKEN=your-hubspot-access-token-here

# HubSpot Blog ID (for blog posts)
# Get from: HubSpot > Marketing > Blog > Settings > Blog ID
HUBSPOT_BLOG_ID=your-blog-id-here

# ============================================
# LinkedIn Configuration
# ============================================

# LinkedIn Access Token
# Get from: LinkedIn Developer Portal > My Apps > Your App > Auth
# Required scopes: w_member_social, w_organization_social, r_organization_social
LINKEDIN_ACCESS_TOKEN=your-linkedin-access-token-here

# LinkedIn Organization ID (Company Page ID)
# Get from: LinkedIn Company Page URL (last part) or Admin view
LINKEDIN_ORGANIZATION_ID=your-linkedin-org-id-here

# ============================================
# Facebook Configuration
# ============================================

# Facebook Page Access Token
# Get from: Facebook Developer Portal > Your App > Tools > Graph API Explorer
# Required permissions: pages_manage_posts, pages_read_engagement
FACEBOOK_ACCESS_TOKEN=your-facebook-page-access-token-here

# Facebook Page ID
# Get from: Facebook Page > About > Page ID
FACEBOOK_PAGE_ID=your-facebook-page-id-here

# ============================================
# Mailchimp Configuration
# ============================================

# Mailchimp API Key
# Get from: Mailchimp > Account > Extras > API Keys
# Format: xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-us21
MAILCHIMP_API_KEY=your-mailchimp-api-key-here

# Mailchimp Server Prefix (extracted from API key, e.g., "us21")
# This is the part after the dash in your API key
MAILCHIMP_SERVER_PREFIX=us21

# Mailchimp Audience/List ID
# Get from: Mailchimp > Audience > Settings > Audience name and defaults
MAILCHIMP_LIST_ID=your-mailchimp-list-id-here

# ============================================
# Asset Generation - Stock Photos
# ============================================

# Pexels API Key
# Get from: https://www.pexels.com/api/
PEXELS_API_KEY=your-pexels-api-key-here

# Unsplash Access Key
# Get from: https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=your-unsplash-access-key-here

# ============================================
# Asset Generation - Canva (Template-Based Design)
# ============================================

# Canva Connect API Key
# Get from: https://www.canva.dev/docs/connect/
CANVA_API_KEY=your-canva-api-key-here

# Canva Brand Kit ID (optional)
# Get from: Canva > Brand Kit > Settings
CANVA_BRAND_KIT_ID=your-brand-kit-id-here

# Canva Template IDs - Configure in Canva, paste IDs here
# Social Media Templates
CANVA_TEMPLATE_LINKEDIN_POST=your-linkedin-post-template-id
CANVA_TEMPLATE_FACEBOOK_POST=your-facebook-post-template-id
CANVA_TEMPLATE_LINKEDIN_ARTICLE=your-linkedin-article-cover-template-id

# Blog & Website Templates
CANVA_TEMPLATE_OG_IMAGE=your-og-image-template-id
CANVA_TEMPLATE_BLOG_HERO=your-blog-hero-template-id

# Ad Templates
CANVA_TEMPLATE_FB_AD_1200=your-facebook-ad-1200x628-template-id
CANVA_TEMPLATE_LI_AD_1200=your-linkedin-ad-1200x627-template-id

# Stats & Proof Point Templates
CANVA_TEMPLATE_STAT_CARD=your-stat-card-template-id
CANVA_TEMPLATE_BEFORE_AFTER=your-before-after-template-id
CANVA_TEMPLATE_PROCESS=your-process-diagram-template-id

# One-Pager Templates
CANVA_TEMPLATE_ONE_PAGER=your-one-pager-cover-template-id

# ============================================
# Asset Generation - AI Video
# ============================================

# Runway ML API Key (Gen-3 Alpha video generation)
# Get from: https://app.runwayml.com/
RUNWAY_API_KEY=your-runway-api-key-here

# Lumen5 API Key (text-to-video, blog video conversion)
# Get from: https://lumen5.com/api/
LUMEN5_API_KEY=your-lumen5-api-key-here

# ============================================
# Optional: OpenAI Configuration
# (For AI-enhanced content generation)
# ============================================

# OpenAI API Key (optional - for enhanced content generation)
# OPENAI_API_KEY=your-openai-api-key-here

# ============================================
# Campaign Defaults
# ============================================

# Default number of social posts per campaign
DEFAULT_SOCIAL_POST_COUNT=3

# Default number of emails in sequence
DEFAULT_EMAIL_COUNT=5

# Default campaign output directory
CAMPAIGNS_DIR=./campaigns
